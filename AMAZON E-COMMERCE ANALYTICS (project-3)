-- =====================================================
-- TASK 1 : CUSTOMER ORDER DETAILS
-- =====================================================

SELECT
    c.customer_name,
    o.order_id,
    o.order_date

FROM customers c

INNER JOIN orders o

ON c.customer_id = o.customer_id;


-- =====================================================
-- TASK 2 : PRODUCT CATEGORY DETAILS
-- =====================================================

SELECT
    p.product_name,
    c.category_name

FROM products p

INNER JOIN categories c

ON p.category_id = c.category_id;


-- =====================================================
-- TASK 3 : CUSTOMER PURCHASE ANALYSIS
-- =====================================================

SELECT
    c.customer_name,
    p.product_name,
    o.quantity

FROM customers c

INNER JOIN orders o

ON c.customer_id = o.customer_id

INNER JOIN products p

ON o.product_id = p.product_id;


-- =====================================================
-- TASK 4 : FULL BUSINESS REPORT
-- =====================================================

SELECT
    c.customer_name,
    p.product_name,
    cat.category_name

FROM customers c

INNER JOIN orders o

ON c.customer_id = o.customer_id

INNER JOIN products p

ON o.product_id = p.product_id

INNER JOIN categories cat

ON p.category_id = cat.category_id;


-- =====================================================
-- TASK 5 : ALL CUSTOMERS EVEN IF NO ORDERS
-- =====================================================

SELECT
    c.customer_name,
    o.order_id

FROM customers c

LEFT JOIN orders o

ON c.customer_id = o.customer_id;


-- =====================================================
-- TASK 6 : ALL ORDERS EVEN IF CUSTOMER MISSING
-- =====================================================

SELECT
    c.customer_name,
    o.order_id

FROM customers c

RIGHT JOIN orders o

ON c.customer_id = o.customer_id;


-- =====================================================
-- TASK 7 : FULL OUTER JOIN
-- =====================================================

SELECT
    c.customer_name,
    o.order_id

FROM customers c

FULL OUTER JOIN orders o

ON c.customer_id = o.customer_id;


-- =====================================================
-- TASK 8 : GOLD MEMBERS ANALYSIS
-- =====================================================

SELECT
    c.customer_name,
    p.product_name

FROM customers c

INNER JOIN orders o

ON c.customer_id = o.customer_id

INNER JOIN products p

ON o.product_id = p.product_id

WHERE c.membership_type = 'Gold';


-- =====================================================
-- TASK 9 : PRODUCTS ABOVE ₹10,000
-- =====================================================

SELECT
    product_name,
    price

FROM products

WHERE price > 10000;


-- =====================================================
-- TASK 10 : ELECTRONICS PRODUCTS
-- =====================================================

SELECT
    p.product_name,
    c.category_name

FROM products p

INNER JOIN categories c

ON p.category_id = c.category_id

WHERE c.category_name = 'Electronics';


