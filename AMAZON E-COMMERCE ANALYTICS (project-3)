-- =====================================================
-- TABLE 2 : CATEGORIES
-- =====================================================

CREATE TABLE categories(

    category_id SERIAL PRIMARY KEY,

    category_name VARCHAR(50) NOT NULL

);

INSERT INTO categories
(category_name)

VALUES

('Electronics'),

('Fashion'),

('Home Appliances'),

